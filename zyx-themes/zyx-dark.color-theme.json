{
  "name": "ZYX Dark",
  "type": "dark",
  "semanticHighlighting": true,

  "semanticTokenColors": {
    "variable": "#e8e0d0",
    "property": "#e8e0d0",
    "variable.readonly": { "foreground": "#DDD2BB", "bold": true },
    "parameter": { "foreground": "#DDD2BB", "italic": true },
    "decorator": { "foreground": "#82bbe8" },
    "function": "#82c9ff",
    "function.async": {"foreground": "#a8d8ff", "italic": true},
    "function.definition": { "bold": true },
    "function.defaultLibrary": { "foreground": "#FCD895" },
    "function.abstract": { "foreground": "#82c9ff", "italic": true },
    "function.static": { "foreground": "#82c9ff", "bold": true },
    "function.deprecated": { "foreground": "#6a6560", "strikethrough": true },
    "method": "#82c9ff",
    "method.async": {"foreground": "#a8d8ff", "italic": true},
    "method.definition": { "bold": true },
    "method.defaultLibrary": { "foreground": "#FCD895" },
    "method.abstract": { "foreground": "#82c9ff", "italic": true },
    "method.static": { "foreground": "#82c9ff", "bold": true },
    "method.deprecated": { "foreground": "#6a6560", "strikethrough": true },
    "class": {"foreground": "#FFC799" },
    "class.definition": { "foreground": "#FFC799", "bold": true },
    "class.abstract": { "foreground": "#FFC799", "italic": true },
    "class.deprecated": { "foreground": "#6a6560", "strikethrough": true },
    "class.defaultLibrary": {"foreground": "#7cc5cc" },
    "interface": "#FFC799",
    "interface.defaultLibrary": {"foreground": "#FFC799" },
    "enum": "#FFC799",
    "enum.defaultLibrary": {"foreground": "#FCD895" },
    "enumMember": "#e8a87c",
    "enumMember.deprecated": { "foreground": "#6a6560", "strikethrough": true },
    "type": {"foreground": "#F7B2B7", "italic": true},
    "typeParameter": {"foreground": "#F7B2B7", "italic": true},
    "namespace": {"foreground": "#FCD895", "bold": true},
    "module": {"foreground": "#FCD895", "bold": true},
    "namespace.defaultLibrary": {"foreground": "#f87b8a" },
    "property.readonly": { "foreground": "#DDD2BB", "bold": true },
    "property.deprecated": { "foreground": "#6a6560", "strikethrough": true },
    "variable.deprecated": { "foreground": "#6a6560", "strikethrough": true },
    "parameter.declaration": { "foreground": "#e8dcc8", "italic": true },
    "string": "#9dcea8",
    "number": "#e8a87c",
    "boolean": "#e8a87c",
    "keyword": "#c792ea",
    "comment": { "foreground": "#5c6370", "italic": true },
    "regexp": "#9dcea8",
    "operator": "#8a8278",
    "macro": "#c792ea",
    "label": "#e8a87c",
    "builtinType": "#7cc5cc",
    "lifetime": { "foreground": "#6a6560", "italic": true },
    "clsParameter": { "bold": true, "italic": true },
    "selfKeyword": { "foreground": "#c792ea", "italic": true },
    "selfParameter": { "bold": true, "italic": true },
    "unresolvedReference": "#c0776a",

    "tomlArrayKey": { "foreground": "#FFC799", },
    "tomlTableKey": { "foreground": "#FFC799" },
  },

