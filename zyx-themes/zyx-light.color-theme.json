  "tokenColors": [
    {
      "scope": "meta.embedded",
      "settings": { "foreground": "#2d2820" }
    },
    {
      "name": "Comments",
      "scope": "comment, punctuation.definition.comment",
      "settings": { "foreground": "#a09080", "fontStyle": "italic" }
    },
    {
      "name": "Variables",
      "scope": "variable",
      "settings": { "foreground": "#1a1612" }
    },
    {
      "name": "Variable readwrite / properties",
      "scope": "variable.other.readwrite, meta.object-literal.key, support.variable.property, support.variable.object.process, support.variable.object.node",
      "settings": { "foreground": "#1a1612" }
    },
    {
      "name": "Variable constant (readonly)",
      "scope": "variable.other.constant",
      "settings": { "foreground": "#2d2010" }
    },
    {
      "name": "Variable language (this/self/super)",
      "scope": "variable.language",
      "settings": { "foreground": "#6a2896" }
    },
    {
      "name": "Python self/cls",
      "scope": "variable.parameter.function.language.special.self.python, variable.parameter.function.language.special.cls.python",
      "settings": { "foreground": "#BF4A5B" }
